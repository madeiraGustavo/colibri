# ============================================================
# Colibri — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your environment.
# All variables below are required unless marked (optional).

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/colibri

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# Auth
# ------------------------------------------------------------
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ------------------------------------------------------------
# Tenant (internal — invisible to frontend)
# ------------------------------------------------------------
DEFAULT_TENANT_ID=colibri

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3333

# ------------------------------------------------------------
# App URLs
# ------------------------------------------------------------
COLIBRI_API_URL=http://localhost:3333
COLIBRI_WEB_URL=http://localhost:3000
# Produção (Render): https://colibri-api-djm1.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3333

# ------------------------------------------------------------
# Storage
# ------------------------------------------------------------
STORAGE_BUCKET=colibri-uploads

# ------------------------------------------------------------
# Node
# ------------------------------------------------------------
NODE_ENV=development
PORT=3333
